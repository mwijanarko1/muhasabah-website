# Public (client-exposed) variables
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud
# Shown in Privacy / footer contact link (optional but recommended for production)
NEXT_PUBLIC_CONTACT_EMAIL=

# Convex Auth - Google OAuth
# Generate AUTH_SECRET with: openssl rand -base64 32
AUTH_SECRET=your-random-secret-here
# Session JWT signing (required on Convex — run: bun run generate-convex-auth-keys)
# Paste JWT_PRIVATE_KEY and JWKS from the script output into the Convex dashboard only.
# Do not put real private keys in this file or commit them.
AUTH_GOOGLE_ID=your-google-client-id
AUTH_GOOGLE_SECRET=your-google-client-secret
# Public origin of this Next.js app (no trailing slash). Required by @convex-dev/auth for OAuth redirects.
# Local: http://localhost:3000 — Production: https://your-domain.com
# Must be set for the Convex deployment (Dashboard → Settings → Environment Variables, or `bunx convex env set`).
SITE_URL=http://localhost:3000
